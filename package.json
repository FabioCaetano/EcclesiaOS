{
  "name": "ecclesiaos",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "dev": "npm run dev --workspace @ecclesiaos/web",
    "dev:web": "npm run dev --workspace @ecclesiaos/web",
    "dev:api": "npm run dev --workspace @ecclesiaos/api",
    "postinstall": "npm run db:generate",
    "build": "npm run build --workspaces",
    "build:web": "npm run build --workspace @ecclesiaos/web",
    "build:api": "npm run build --workspace @ecclesiaos/api",
    "db:generate": "npm run db:generate --workspace @ecclesiaos/api",
    "db:migrate": "npm run db:migrate --workspace @ecclesiaos/api",
    "db:migrate:deploy": "npm run db:migrate:deploy --workspace @ecclesiaos/api",
    "db:push": "npm run db:push --workspace @ecclesiaos/api",
    "db:verify": "npm run db:verify --workspace @ecclesiaos/api",
    "test": "npm run test --workspace @ecclesiaos/api",
    "test:web": "npm run build:api && npm run test:e2e --workspace @ecclesiaos/web",
    "typecheck": "npm run typecheck --workspaces",
    "reset-dev-data": "npm run reset-dev-data --workspace @ecclesiaos/api"
  },
  "devDependencies": {
    "typescript": "^5.8.3"
  },
  "engines": {
    "node": ">=20"
  }
}
