generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model ChurchProfileRecord {
  id           String @id
  name         String
  email        String
  phone        String
  website      String
  youtubeChannelUrl String @default("")
  addressLine1 String
  addressLine2 String
  city         String
  state        String
  postalCode   String
  country      String
}

model UserRecord {
  id       String @id
  name     String
  email    String @unique
  password String
  role     String
  personId String
}

model PersonRecord {
  id        String   @id
  firstName String
  lastName  String
  email     String
  phone     String
  birthDate String
  status    String
  guardianPersonIds Json @default("[]")
  notes     String
  createdAt DateTime
  updatedAt DateTime
}

model GroupRecord {
  id              String   @id
  name            String
  type            String
  description     String
  leaderPersonId  String
  memberPersonIds Json
  createdAt       DateTime
  updatedAt       DateTime
}

model AttendanceRecord {
  id               String   @id
  date             String
  type             String
  eventId          String
  groupId          String
  presentPersonIds Json
  notes            String
  createdAt        DateTime
  updatedAt        DateTime
}

model EventRecord {
  id          String   @id
  title       String
  type        String
  date        String
  startTime   String
  endTime     String
  location    String
  groupId     String
  recurrence  String
  recurrenceUntil String
  recurrenceRule String @default("")
  parentEventId String @default("")
  requestedTeamIds Json @default("[]")
  registrationEnabled Boolean @default(false)
  registrationCapacity Int @default(0)
  registrationPrice Float @default(0)
  registrationCurrency String @default("BRL")
  registrationSlug String @unique @default("")
  description String
  createdAt   DateTime
  updatedAt   DateTime

  @@index([parentEventId])
}

model EventRegistrationRecord {
  id        String   @id
  eventId   String
  name      String
  email     String
  phone     String
  quantity  Int
  amountDue Float
  status    String
  ticketCode String @default("")
  checkedInAt String @default("")
  checkedInByUserId String @default("")
  notes     String
  createdAt DateTime
}

model ChurchResourceRecord {
  id          String   @id
  name        String
  location    String
  capacity    Int
  description String
  isActive    Boolean
  createdAt   DateTime
  updatedAt   DateTime
}

model RoomReservationRecord {
  id         String   @id
  resourceId String
  eventId    String
  title      String
  date       String
  startTime  String
  endTime    String
  reservedBy String
  status     String
  notes      String
  createdAt  DateTime
  updatedAt  DateTime
}

model EventCheckInRecord {
  id          String   @id
  eventId     String
  personId    String
  checkedInAt DateTime
  notes       String
}

model ChildCheckInRecord {
  id            String   @id
  eventId       String
  childPersonId String   @default("")
  childName     String
  guardianPersonId String @default("")
  guardianName  String
  guardianPhone String
  securityCode  String
  checkedInAt   DateTime
  checkedOutAt  String
  checkedOutByPersonId String @default("")
  notes         String
}

model ServingPlanRecord {
  id          String   @id
  date        String
  title       String
  groupId     String
  eventId     String   @default("")
  notes       String
  assignments Json
  createdAt   DateTime
  updatedAt   DateTime

  @@index([eventId])
  @@index([groupId])
}

model FinancialTransactionRecord {
  id            String   @id
  date          String
  type          String
  amount        Float
  fund          String
  category      String
  paymentMethod String
  personId      String
  description   String
  createdAt     DateTime
  updatedAt     DateTime
}

model LabelTemplateRecord {
  id           String   @id
  name         String
  printerModel String   @default("")
  widthMm      Float    @default(62)
  heightMm     Float    @default(100)
  isContinuous Boolean  @default(false)
  layout       String   @default("kids_checkin")
  isDefault    Boolean  @default(false)
  createdAt    DateTime
  updatedAt    DateTime

  @@index([layout])
}

model PeopleMessageRecord {
  id                 String   @id
  subject            String
  body               String
  channel            String   @default("manual")
  recipientPersonIds Json     @default("[]")
  createdAt          DateTime
  createdByUserId    String   @default("")
  createdByName      String   @default("")

  @@index([createdAt])
}

model AuditLogRecord {
  id          String   @id
  action      String
  entityType  String
  entityId    String
  actorUserId String
  actorName   String
  summary     String
  createdAt   DateTime
}
