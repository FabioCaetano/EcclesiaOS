{
  "name": "@ecclesiaos/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -b tsconfig.json",
    "db:generate": "prisma generate --schema prisma/schema.prisma",
    "db:migrate": "prisma migrate dev --schema prisma/schema.prisma",
    "db:migrate:deploy": "prisma migrate deploy --schema prisma/schema.prisma",
    "db:push": "prisma db push --schema prisma/schema.prisma",
    "db:verify": "npm run build && node dist/scripts/verifyPrisma.js",
    "start": "node dist/server.js",
    "test": "npm run build && node --test dist/**/*.test.js",
    "typecheck": "tsc -b tsconfig.json --pretty false",
    "reset-dev-data": "npm run build && node dist/scripts/resetDevData.js"
  },
  "dependencies": {
    "@ecclesiaos/shared": "file:../../packages/shared",
    "@prisma/client": "^6.19.3",
    "cron-parser": "^5.5.0",
    "prisma": "^6.19.3"
  },
  "devDependencies": {
    "@types/node": "^24.0.3",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3"
  }
}
